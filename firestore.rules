rules_version = '2';

// ⚠️ DEVELOPMENT-ONLY rules — DO NOT ship to production.
// These rules allow any client (including anonymous) to read & write the
// `notes` collection. Before going live, replace them with rules that
// authenticate the user and restrict access to their own documents.

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the users collection
    match /users/{userId} {
      // Any authenticated user can read other users (required for the leaderboard)
      allow read: if request.auth != null;

      // Only the user themselves can write/update their own profile data
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // If you have categories/questions collections, make sure they are readable too
    match /categories/{categoryId} {
      allow read: if true;
    }

    // Notes collection: any signed-in user can read; only the owner can write.
    // Each note document stores `userId` so we can scope writes.
    match /notes/{noteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }
  }
}